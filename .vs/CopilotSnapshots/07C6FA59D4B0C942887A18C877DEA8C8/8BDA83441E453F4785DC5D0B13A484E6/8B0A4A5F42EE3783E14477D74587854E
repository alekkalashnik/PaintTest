using FlaUI.Core;
using FlaUI.Core.AutomationElements;
using FlaUI.UIA3;
using PaintTest.Pages;
using System.Diagnostics;
using static System.Windows.Forms.VisualStyles.VisualStyleElement.Window;

namespace PaintTest.Core
{
    public class ApplicationManager : IDisposable
    {
        private Application? _application;
        private UIA3Automation? _automation;
        private const string PAINT_PATH = "mspaint.exe";
        private const int LAUNCH_TIMEOUT_MS = 10000;

        public Application Application => _application ?? throw new InvalidOperationException("Application not started");
        public UIA3Automation Automation => _automation ?? throw new InvalidOperationException("Automation not initialized");
        public Window MainWindow => Application.GetMainWindow(Automation, TimeSpan.FromMilliseconds(LAUNCH_TIMEOUT_MS));

        public void StartApplication()
        {
            if (_application != null)
            {
                throw new InvalidOperationException("Application already started");
            }

            _automation = new UIA3Automation();
            
            // Start Paint application
            _application = Application.Launch(PAINT_PATH);
            
            // Wait for main window to be available with a simple timeout
            var timeout = DateTime.Now.AddMilliseconds(LAUNCH_TIMEOUT_MS);
            while (DateTime.Now < timeout)
            {
                try
                {
                    var window = MainWindow;
                    if (window != null && window.IsAvailable)
                    {
                        // Give UI a moment to fully initialize
                        Thread.Sleep(500);
                        break;
                    }
                }
                catch
                {
                    // Window not yet available
                }
                Thread.Sleep(100);
            }
        }

        public void CloseApplication(SavePromptAction saveAction = SavePromptAction.DontSave)
        {
            if (_application == null) return;

            try
            {
                if (_application.HasExited) return;
            }
            catch (InvalidOperationException)
            {
                // Process already disposed/exited
                return;
            }

            // Capture the process before calling Close to avoid losing reference
            var process = _application.Process;

            _application.Close();

            // Handle the "Do you want to save your work?" popup using the provided strategy
            try
            {
                var window = MainWindow;
                var saveDialog = SaveChangesDialogPage.FindDialog(window, 3000);
                if (saveDialog != null && saveDialog.IsDisplayed)
                {
                    switch (saveAction)
                    {
                        case SavePromptAction.Cancel:
                            saveDialog.ClickCancel();
                            saveDialog.WaitForClose(2000);
                            // User canceled close; abort waiting and return
                            return;
                        case SavePromptAction.DontSave:
                            saveDialog.ClickDontSave();
                            saveDialog.WaitForClose(2000);
                            break;
                        case SavePromptAction.Save:
                            saveDialog.ClickSave();
                            // Note: Save may bring up a Save As dialog; we just close the confirmation dialog here
                            saveDialog.WaitForClose(2000);
                            break;
                    }
                }
            }
            catch
            {
                // If main window is unavailable or any UIA error occurs, continue to wait for process exit
            }

            // Wait for application to close using the captured process
            var timeout = DateTime.Now.AddSeconds(5);
            try
            {
                while (!process.HasExited && DateTime.Now < timeout)
                {
                    Thread.Sleep(100);
                }
            }
            catch (InvalidOperationException)
            {
                // Process became disassociated - treat as exited
            }
        }

        public void Dispose()
        {
            CloseApplication(SavePromptAction.DontSave);
            _application?.Dispose();
            _automation?.Dispose();
        }
    }

    public enum SavePromptAction
    {
        Cancel,
        DontSave,
        Save
    }
}